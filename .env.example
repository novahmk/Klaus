# Klaus V2 - Configuração de Ambiente

# OpenAI
OPENAI_API_KEY=sk_test_your_api_key_here
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# Redis (Cache + memória de curto prazo)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL (Banco de dados)
DATABASE_URL=postgresql://user:password@localhost:5432/klaus
PG_POOL_MAX=10

# Memória / Conversas
MAX_HISTORY_MESSAGES=20
COLD_CONTEXT_HOURS=4
DEFAULT_CLIENTE_ID=default

# WASenderAPI (Recebimento de mensagens)
WASENDERAPI_TOKEN=
WASENDERAPI_BASE_URL=https://www.wasenderapi.com/api
WASENDERAPI_WEBHOOK_SECRET=
PORT=8080
# 'queue' = enfileira no Componente 8 | 'direct' = chama o Orquestrador direto
PROCESSING_MODE=queue

# Logs
LOG_LEVEL=info

# Ambiente
NODE_ENV=development

# ========================================
# SPRINT 0.5+: Supabase Integration (novo)
# ========================================

# Supabase Credentials (Sprint 0.5+)
SUPABASE_URL=https://your-project.supabase.co
# Formato legado (JWT) OU novo formato de chaves do Supabase — defina um dos dois pares.
# Legado (JWT, começa com eyJ...):
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
# Novo formato (prefixo sb_secret_.../sb_publishable_...) — usado como fallback
# se as variáveis legadas acima não estiverem definidas:
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=

# ========================================
# FASE 0: Feature Flags (ativar progressivamente)
# ========================================

# Sprint 0.5+: Supabase Enabled (default: false para rollout seguro)
SUPABASE_ENABLED=false

# Sprint 1: Config Loader (default: false)
CONFIG_LOADER_ENABLED=false
CONFIG_CACHE_TTL_MS=300000

# Sprint 2: Inbound Supabase Write + Controle Manual (default: false)
INBOUND_SUPABASE_WRITE_ENABLED=false
CONTROL_MANUAL_ENABLED=false

# Sprint 3: Dynamic Prompt from Dashboard (default: false)
DYNAMIC_PROMPT_ENABLED=false

# Sprint 4: Follow-up Automático (default: false)
FOLLOWUP_ENABLED=false

# Sprint 5: Métricas Diárias (default: false)
METRICS_CRON_ENABLED=false

# Sprint 6: Health Check Supabase (default: false)
HEALTH_CHECK_SUPABASE_ENABLED=false

# Sprint 7: Scoring de Qualificação Dinâmico via Dashboard (default: false)
DYNAMIC_SCORING_ENABLED=false

# Sprint 8: Regras de Conversa Dinâmicas via Dashboard (default: false)
DYNAMIC_RULES_ENABLED=false
