{
  "name": "klaus-v2",
  "version": "2.0.0",
  "description": "Klaus V2 - AI-powered Sales Development Representative",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && npm run copy:migrations && npm run verify:build",
    "copy:migrations": "mkdir -p dist/infra/database/migrations && cp src/infra/database/migrations/*.sql dist/infra/database/migrations/",
    "verify:build": "test \"$(ls -1 src/infra/database/migrations/*.sql | wc -l)\" = \"$(ls -1 dist/infra/database/migrations/*.sql | wc -l)\" || (echo 'ERRO: migrations não copiadas para dist/' && exit 1)",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "migrate": "ts-node src/infra/database/migrate.ts",
    "migrate:prod": "node dist/infra/database/migrate.js"
  },
  "keywords": [
    "sdr",
    "sales",
    "ai",
    "conversational"
  ],
  "author": "Klaus Team",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "ioredis": "$ioredis"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "bullmq": "^5.78.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.11.1",
    "openai": "^4.47.1",
    "pg": "^8.21.0",
    "pino": "^8.17.2",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.2",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.1.1",
    "eslint": "^8.56.0",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.1.1"
  }
}
